#! /usr/bin/env python3

"""This script is designed to run Nexus's test suite using Pytest.

In general, it should only be run by users who have installed Nexus and
are looking to ensure their installation works in their environment.

Developers should NOT use this script to run the test suite as it will
suppress all warnings and fail fast, which is generally not desirable
for development.
"""

import sys

try:
    import pytest
except ImportError:
    print(
        "You must have pytest installed to run Nexus's testing suite!\n"
        "You can install it using one of the following commands:\n"
        "$ pip3 install pytest\n"
        "$ uv pip install pytest\n\n"
        "It is also recommended to install pytest-order to aid in potential debugging:\n"
        "$ pip3 install pytest-order\n"
        "$ uv pip install pytest-order\n"
    )
    sys.exit(1)

if __name__ == "__main__":

    import os
    from pathlib import Path

    test_dir = Path(__file__).resolve().parent.parent / "tests"

    try:
        # This makes the output from pytest cleaner in that it doesn't print
        # the full path from the user's CWD to the Nexus libraries.
        os.chdir(test_dir)
    except PermissionError:
        pass

    retcode = pytest.main([
        "--exitfirst",
        "--disable-warnings",
       f"{test_dir}",
    ])

    sys.exit(retcode)
